# Native Agent Composition Demo

```elixir
Mix.install(
  [
    {:jido_composer, path: Path.join(__DIR__, "..")},
    {:kino, "~> 0.14"}
  ],
  config: [
    jido_action: [default_timeout: :timer.minutes(5)]
  ]
)
```

## Introduction

This livebook demonstrates the **six new native composition capabilities** in Jido Composer.
It builds progressively from simple demos to a complex multi-level pipeline that combines
everything.

| #   | Capability                 | What it does                                                                   |
| --- | -------------------------- | ------------------------------------------------------------------------------ |
| 1   | **AgentNode.run/3**        | Nest agents inside workflows and orchestrators natively -- no wrapper Actions  |
| 2   | **NodeIO**                 | Typed output envelopes (`:map`, `:text`, `:object`) with automatic adaptation  |
| 3   | **Context Layers**         | Ambient (read-only) + working (mutable) + fork functions at agent boundaries   |
| 4   | **Directive-Based FanOut** | Parallel branches with mixed agent/action types, backpressure, error policies  |
| 5   | **Generalized Suspension** | Pause for any reason: human input, rate limits, external jobs, custom          |
| 6   | **Checkpoint/Thaw**        | Serialize suspended agents, restore them later, resume from where they stopped |

Each section is self-contained. Section 7 is the "grand finale" that weaves all six together
in a realistic multi-level agent pipeline with loops, suspension deep in a sub-agent, and
full checkpoint/resume.

## Shared Helpers

```elixir
# Aliases used throughout
alias Jido.Agent.Directive
alias Jido.Agent.Strategy.State, as: StratState
alias Jido.Composer.{Context, NodeIO, Suspension, Checkpoint, Resume}
alias Jido.Composer.Directive.{FanOutBranch, Suspend}
alias Jido.Composer.HITL.{ApprovalRequest, ApprovalResponse}
alias Jido.Composer.Node.{ActionNode, AgentNode, FanOutNode, HumanNode}
alias Jido.Composer.Workflow.Strategy, as: WorkflowStrategy
alias Jido.Composer.Orchestrator.Strategy, as: OrchestratorStrategy

# DirectiveRunner: executes directives synchronously for demo purposes.
# Returns {:ok, agent} | {:suspend, agent, directive} | {:error, reason}
defmodule Demo.DirectiveRunner do
  @moduledoc false

  def run_until_done(module, agent, directives) do
    case run(module, agent, directives) do
      {:ok, agent} -> {:ok, agent}
      {:error, reason} -> {:error, reason}
      {:suspend, agent, directive} -> {:suspend, agent, directive}
    end
  end

  def run(module, agent, directives) do
    run_loop(module, agent, directives)
  end

  defp run_loop(_module, agent, []), do: check_terminal(agent)

  defp run_loop(module, agent, [directive | rest]) do
    case directive do
      %Directive.RunInstruction{instruction: instr, result_action: result_action} ->
        payload = execute_sync(instr)
        {agent, new_directives} = module.cmd(agent, {result_action, payload})
        run_loop(module, agent, new_directives ++ rest)

      %Directive.SpawnAgent{agent: child_module, tag: tag, opts: spawn_opts} ->
        payload = Jido.Composer.Node.execute_child_sync(child_module, spawn_opts)
        {agent, new_directives} = module.cmd(agent, {:workflow_child_result, %{tag: tag, result: payload}})
        run_loop(module, agent, new_directives ++ rest)

      %FanOutBranch{} = _first ->
        {fan_out_directives, remaining} =
          Enum.split_with([directive | rest], &match?(%FanOutBranch{}, &1))

        results = execute_fan_out_branches(fan_out_directives)

        {agent, all_directives} =
          Enum.reduce(results, {agent, []}, fn {name, result}, {acc, acc_dirs} ->
            {new_agent, new_dirs} = module.cmd(acc, {:fan_out_branch_result, %{branch_name: name, result: result}})
            {new_agent, acc_dirs ++ new_dirs}
          end)

        run_loop(module, agent, all_directives ++ remaining)

      %Suspend{} = suspend ->
        {:suspend, agent, suspend}

      _other ->
        run_loop(module, agent, rest)
    end
  end

  defp execute_sync(%Jido.Instruction{action: action_module, params: params}) do
    case Jido.Exec.run(action_module, params, %{}, timeout: 0) do
      {:ok, result} -> %{status: :ok, result: result}
      {:ok, result, outcome} -> %{status: :ok, result: result, outcome: outcome}
      {:error, reason} -> %{status: :error, result: %{error: reason}}
    end
  end

  defp execute_fan_out_branches(directives) do
    directives
    |> Task.async_stream(
      fn %FanOutBranch{} = branch ->
        result = execute_branch(branch)
        {branch.branch_name, result}
      end,
      timeout: 30_000, on_timeout: :kill_task, ordered: true
    )
    |> Enum.zip(directives)
    |> Enum.map(fn
      {{:ok, {name, result}}, _} -> {name, result}
      {{:exit, reason}, branch} -> {branch.branch_name, {:error, {:crashed, reason}}}
    end)
  end

  defp execute_branch(%FanOutBranch{instruction: {:function, fun, ctx}}), do: fun.(ctx)

  defp execute_branch(%FanOutBranch{instruction: %Jido.Instruction{} = instr}) do
    case execute_sync(instr) do
      %{status: :ok, result: result} -> {:ok, result}
      %{status: :error, result: %{error: reason}} -> {:error, reason}
    end
  end

  defp execute_branch(%FanOutBranch{spawn_agent: spawn_info}) do
    Jido.Composer.Node.execute_child_sync(spawn_info.agent, spawn_info.opts)
  end

  defp check_terminal(agent) do
    strat = StratState.get(agent)
    case strat.status do
      :success -> {:ok, agent}
      :failure -> {:error, :workflow_failed}
      _ -> {:ok, agent}
    end
  end
end

# Action modules for demos (test support modules aren't available in livebook)
defmodule Demo.AccumulatorAction do
  use Jido.Action,
    name: "accumulator",
    description: "Stores a tag value",
    schema: [tag: [type: :string, required: true, doc: "Tag to append"]]

  def run(%{tag: tag}, _ctx), do: {:ok, %{tag: tag}}
end

defmodule Demo.NoopAction do
  use Jido.Action,
    name: "noop",
    description: "Does nothing",
    schema: []

  def run(_params, _ctx), do: {:ok, %{}}
end

defmodule Demo.ExtractAction do
  use Jido.Action,
    name: "extract",
    description: "Simulates data extraction",
    schema: [source: [type: :string, required: true, doc: "Data source"]]

  def run(%{source: source}, _ctx) do
    {:ok, %{records: [%{id: 1, source: source}, %{id: 2, source: source}], count: 2}}
  end
end

defmodule Demo.TransformAction do
  use Jido.Action,
    name: "transform",
    description: "Transforms records by uppercasing source",
    schema: [extract: [type: :map, required: false]]

  def run(params, _ctx) do
    records = get_in(params, [:extract, :records]) || []
    transformed = Enum.map(records, fn rec -> Map.update(rec, :source, "", &String.upcase/1) end)
    {:ok, %{records: transformed, count: length(transformed)}}
  end
end

defmodule Demo.LoadAction do
  use Jido.Action,
    name: "load",
    description: "Simulates loading records into storage",
    schema: [transform: [type: :map, required: false]]

  def run(params, _ctx) do
    records = get_in(params, [:transform, :records]) || []
    {:ok, %{loaded: length(records), status: :complete}}
  end
end

defmodule Demo.EchoAction do
  use Jido.Action,
    name: "echo",
    description: "Echoes input message",
    schema: [message: [type: :string, required: true]]

  def run(%{message: message}, _ctx), do: {:ok, %{echoed: message}}
end

defmodule Demo.FailAction do
  use Jido.Action,
    name: "fail",
    description: "Always fails",
    schema: [reason: [type: :string, required: false]]

  def run(params, _ctx), do: {:error, Map.get(params, :reason, "intentional failure")}
end

defmodule Demo.RateLimitAction do
  use Jido.Action,
    name: "rate_limit_action",
    description: "Simulates rate-limited operation",
    schema: [tokens: [type: :integer, required: false]]

  def run(params, _ctx) do
    tokens = Map.get(params, :tokens, 0)
    if tokens > 0 do
      {:ok, %{processed: true, tokens_remaining: tokens - 1}}
    else
      {:ok, suspension} = Jido.Composer.Suspension.new(
        reason: :rate_limit,
        metadata: %{retry_after_ms: 5000}
      )
      {:ok, %{processed: false, __suspension__: suspension}, :suspend}
    end
  end
end

# Jido.Agent generates functions with iex> doctests that Livebook tries to run.
# This macro suppresses them by overriding with @doc false.
defmodule Demo.Helpers do
  defmacro suppress_agent_doctests do
    quote do
      @doc false
      def plugins, do: super()
      @doc false
      def capabilities, do: super()
      @doc false
      def signal_types, do: super()
    end
  end

  # Named function for FanOut branch (lambdas can't be Macro.escape'd in livebook)
  def compute_branch(ctx) do
    {:ok, %{computed: true, input: ctx[:source] || "none"}}
  end
end

IO.puts("Helpers loaded.")
```

## 1. AgentNode -- Native Agent Nesting

Before native composition, nesting an agent inside a workflow required wrapping it
in a hand-written `Jido.Action`. Now you just drop the agent module into the `nodes` map.

```elixir
# A simple inner workflow agent that does Extract -> Transform -> Load
defmodule Demo.InnerETL do
  @moduledoc false
  use Jido.Composer.Workflow,
    name: "inner_etl",
    description: "Inner ETL sub-pipeline",
    nodes: %{
      extract: Demo.ExtractAction,
      transform: Demo.TransformAction,
      load: Demo.LoadAction
    },
    transitions: %{
      {:extract, :ok} => :transform,
      {:transform, :ok} => :load,
      {:load, :ok} => :done,
      {:_, :error} => :failed
    },
    initial: :extract

  require Demo.Helpers
  Demo.Helpers.suppress_agent_doctests()
end

# Outer workflow: prepare -> run inner ETL agent natively -> finalize
defmodule Demo.OuterPipeline do
  @moduledoc false
  use Jido.Composer.Workflow,
    name: "outer_pipeline",
    description: "Demonstrates native agent nesting",
    nodes: %{
      prepare: Demo.AccumulatorAction,
      etl: Demo.InnerETL,                              # <-- Agent directly! No wrapper!
      finalize: Demo.NoopAction
    },
    transitions: %{
      {:prepare, :ok} => :etl,
      {:etl, :ok} => :finalize,
      {:finalize, :ok} => :done,
      {:_, :error} => :failed
    },
    initial: :prepare

  require Demo.Helpers
  Demo.Helpers.suppress_agent_doctests()
end

agent = Demo.OuterPipeline.new()
{:ok, ctx} = Demo.OuterPipeline.run_sync(agent, %{tag: "start", source: "demo_db"})

IO.puts("=== Native Agent Nesting ===")
IO.puts("Outer workflow ran inner ETL agent as a native node.")
IO.puts("Inner ETL extracted #{ctx[:etl][:extract][:count]} records, transformed, and loaded.")
IO.inspect(ctx, label: "Full context", pretty: true)
```

## 2. NodeIO -- Typed Output Envelopes

NodeIO wraps node output with type metadata. When an orchestrator returns text,
the workflow automatically adapts it to `%{text: "..."}` for map-based context merging.

```elixir
# Demonstrate the three NodeIO types
io_map = NodeIO.map(%{score: 95, grade: "A"})
io_text = NodeIO.text("The analysis reveals strong performance across all metrics.")
io_object = NodeIO.object(%{entities: ["User", "Order", "Product"]}, %{type: "domain_model"})

IO.puts("=== NodeIO Types ===")

for {label, io} <- [{"Map", io_map}, {"Text", io_text}, {"Object", io_object}] do
  IO.puts("\n#{label}:")
  IO.puts("  type:       #{io.type}")
  IO.puts("  mergeable?: #{NodeIO.mergeable?(io)}")
  IO.puts("  to_map:     #{inspect(NodeIO.to_map(io))}")
  IO.puts("  unwrap:     #{inspect(NodeIO.unwrap(io))}")
end
```

```elixir
# Show how NodeIO.text gets adapted automatically in a workflow context
# When Machine.apply_result receives a NodeIO, it calls to_map/1

alias Jido.Composer.Workflow.Machine

nodes = %{
  step: %ActionNode{action_module: Demo.EchoAction}
}

machine = Machine.new(
  nodes: nodes,
  transitions: %{{:step, :ok} => :done},
  initial: :step
)

# Simulate receiving a NodeIO.text result (like from an orchestrator child)
text_result = NodeIO.text("LLM analysis complete: all tests passing")
adapted_machine = Machine.apply_result(machine, text_result)

IO.puts("\n=== NodeIO Auto-Adaptation ===")
IO.puts("Orchestrator returned: NodeIO.text(\"LLM analysis complete...\")")
IO.puts("Machine adapted it to: #{inspect(adapted_machine.context.working)}")
IO.puts("The text is now accessible as ctx[:step][:text] in subsequent nodes.")
```

## 3. Context Layers -- Ambient, Working, and Fork Functions

Context separates read-only **ambient** data (org_id, trace_id) from **working** data
that accumulates through the pipeline. **Fork functions** transform the ambient data
at agent boundaries (e.g., incrementing nesting depth).

```elixir
# Fork function module
defmodule Demo.Forks do
  def increment_depth(ambient, _working) do
    Map.update(ambient, :depth, 1, &(&1 + 1))
  end

  def add_correlation_id(ambient, _working) do
    Map.put(ambient, :correlation_id, "corr-#{:crypto.strong_rand_bytes(4) |> Base.encode16(case: :lower)}")
  end
end

# Create a context with ambient data and fork functions
ctx = Context.new(
  ambient: %{org_id: "acme-corp", region: "us-east-1", depth: 0, trace_id: "tr-demo-001"},
  working: %{pipeline_name: "context_demo"},
  fork_fns: %{
    depth: {Demo.Forks, :increment_depth, []},
    correlation: {Demo.Forks, :add_correlation_id, []}
  }
)

IO.puts("=== Context Layers ===")
IO.puts("\nAmbient (read-only):")
IO.puts("  org_id:   #{Context.get_ambient(ctx, :org_id)}")
IO.puts("  region:   #{Context.get_ambient(ctx, :region)}")
IO.puts("  depth:    #{Context.get_ambient(ctx, :depth)}")
IO.puts("  trace_id: #{Context.get_ambient(ctx, :trace_id)}")

IO.puts("\nWorking (mutable):")
IO.inspect(ctx.working, label: "  working")

# Apply a result -- only working changes
ctx2 = Context.apply_result(ctx, :step1, %{records: 42})
IO.puts("\nAfter apply_result(:step1):")
IO.puts("  ambient unchanged? #{ctx2.ambient == ctx.ambient}")
IO.inspect(ctx2.working, label: "  working")

# Fork for child -- ambient is transformed, working is unchanged
child_ctx = Context.fork_for_child(ctx)
IO.puts("\nAfter fork_for_child:")
IO.puts("  child depth: #{Context.get_ambient(child_ctx, :depth)}")
IO.puts("  child has new correlation_id: #{Context.get_ambient(child_ctx, :correlation_id)}")
IO.puts("  ambient org_id preserved: #{Context.get_ambient(child_ctx, :org_id)}")

# to_flat_map -- what nodes actually see
flat = Context.to_flat_map(ctx)
IO.puts("\nFlat map (what nodes receive):")
IO.puts("  __ambient__: #{inspect(flat[:__ambient__])}")
IO.puts("  pipeline_name: #{flat[:pipeline_name]}")
```

```elixir
# Context layers in a real workflow with ambient configuration

defmodule Demo.ContextWorkflow do
  @moduledoc false
  use Jido.Composer.Workflow,
    name: "context_workflow",
    description: "Workflow with ambient context flow",
    nodes: %{
      extract: Demo.ExtractAction,
      transform: Demo.TransformAction,
      load: Demo.LoadAction
    },
    transitions: %{
      {:extract, :ok} => :transform,
      {:transform, :ok} => :load,
      {:load, :ok} => :done,
      {:_, :error} => :failed
    },
    initial: :extract,
    ambient: [:org_id, :trace_id]

  require Demo.Helpers
  Demo.Helpers.suppress_agent_doctests()
end

agent = Demo.ContextWorkflow.new()
{:ok, ctx} = Demo.ContextWorkflow.run_sync(agent, %{
  source: "context_db",
  org_id: "acme-corp",
  trace_id: "tr-ctx-demo"
})

IO.puts("=== Context in Workflow ===")
IO.puts("Ambient data (org_id, trace_id) separated from working data.")
IO.puts("org_id and trace_id went to ambient; source went to working.")
IO.inspect(ctx[:__ambient__], label: "Ambient layer")
IO.inspect(ctx[:extract], label: "Extract results")
IO.inspect(ctx[:load], label: "Load results")
IO.puts("\nNote: fork_fns are demonstrated in the Context Layers section above.")
IO.puts("In the DSL, fork_fns use MFA tuples which require compile-time module resolution.")
```

## 4. Directive-Based FanOut -- Parallel Branches with Mixed Types

FanOut decomposes into individual `FanOutBranch` directives. Branches can be actions,
agents, or functions. Supports `max_concurrency` for backpressure and `:fail_fast` /
`:collect_partial` error policies.

```elixir
# Inner agent that will be one of the FanOut branches
defmodule Demo.EnrichAgent do
  @moduledoc false
  use Jido.Composer.Workflow,
    name: "enrich_agent",
    description: "Two-step enrichment sub-pipeline",
    nodes: %{
      transform: Demo.TransformAction,
      load: Demo.LoadAction
    },
    transitions: %{
      {:transform, :ok} => :load,
      {:load, :ok} => :done,
      {:_, :error} => :failed
    },
    initial: :transform

  require Demo.Helpers
  Demo.Helpers.suppress_agent_doctests()
end

# Build FanOut with mixed branch types: action + agent + function reference
{:ok, extract_node} = ActionNode.new(Demo.ExtractAction)
{:ok, enrich_node} = AgentNode.new(Demo.EnrichAgent)

{:ok, fan_out} = FanOutNode.new(
  name: "parallel_processing",
  branches: [
    extract: extract_node,                                     # ActionNode branch
    enrich: enrich_node,                                       # AgentNode branch
    compute: &Demo.Helpers.compute_branch/1                    # Function branch (named, not lambda)
  ],
  max_concurrency: 2,        # Only 2 branches run at a time
  on_error: :collect_partial  # Continue even if a branch fails
)

# Note: FanOutNode structs contain function references, which can't be passed into
# the `use Jido.Composer.Workflow` macro (Macro.escape doesn't support closures).
# Instead, we build the workflow manually using the Machine and DirectiveRunner.

alias Jido.Composer.Workflow.Machine

machine = Machine.new(
  nodes: %{
    parallel: fan_out,
    finalize: ActionNode.new(Demo.NoopAction) |> elem(1)
  },
  transitions: %{
    {:parallel, :ok} => :finalize,
    {:finalize, :ok} => :done,
    {:_, :error} => :failed
  },
  initial: :parallel,
  context: %{source: "fanout_db"}
)

# Execute the FanOut node directly
node = Machine.current_node(machine)
{:ok, result} = FanOutNode.run(node, Context.to_flat_map(machine.context), [])
machine = Machine.apply_result(machine, result)
{:ok, machine} = Machine.transition(machine, :ok)

# Execute finalize
finalize_node = Machine.current_node(machine)
{:ok, finalize_result} = Jido.Composer.Node.ActionNode.run(finalize_node, Context.to_flat_map(machine.context), [])
machine = Machine.apply_result(machine, finalize_result)
{:ok, machine} = Machine.transition(machine, :ok)

ctx = Context.to_flat_map(machine.context)

IO.puts("=== Directive-Based FanOut ===")
IO.puts("Three branches ran in parallel (max_concurrency: 2):")
IO.puts("  - extract (ActionNode): #{inspect(ctx[:parallel][:extract][:count])} records")
IO.puts("  - enrich (AgentNode):   loaded #{inspect(ctx[:parallel][:enrich][:load][:loaded])} records")
IO.puts("  - compute (function):   #{inspect(ctx[:parallel][:compute])}")
```

```elixir
# Demonstrate fail_fast: one bad branch cancels the rest
{:ok, extract_node} = ActionNode.new(Demo.ExtractAction)
{:ok, fail_node} = ActionNode.new(Demo.FailAction)

{:ok, fail_fast_fan} = FanOutNode.new(
  name: "fail_fast_demo",
  branches: [
    good: extract_node,
    bad: fail_node
  ],
  on_error: :fail_fast
)

# FanOutNode structs can't be Macro.escape'd into `use Workflow` DSL.
# Run the FanOut node directly to demonstrate fail_fast behavior.
result = FanOutNode.run(fail_fast_fan, %{source: "test", reason: "boom"}, [])

IO.puts("\n=== Fail-Fast FanOut ===")
IO.puts("One branch failed -> entire FanOut failed: #{inspect(result)}")
```

## 5. Generalized Suspension -- Beyond Human-in-the-Loop

Suspension is now a unified concept. A flow can pause for **any reason** -- human input,
rate limits, external jobs, async operations, or custom application logic. Each reason
carries typed metadata and an optional timeout.

```elixir
# All five suspension reasons
reasons = [
  {:human_input, [metadata: %{urgency: :high}]},
  {:rate_limit, [metadata: %{retry_after_ms: 5000, tokens_remaining: 0}]},
  {:async_completion, [metadata: %{task_id: "async-42"}, resume_signal: "task.complete"]},
  {:external_job, [metadata: %{job_id: "ci-build-99", webhook: "/hooks/ci"}, timeout: 300_000]},
  {:custom, [metadata: %{type: "budget_exceeded", amount: 150.0, limit: 100.0}]}
]

IO.puts("=== Suspension Reasons ===\n")

for {reason, opts} <- reasons do
  {:ok, suspension} = Suspension.new([reason: reason] ++ opts)
  IO.puts("#{String.pad_trailing(to_string(reason), 20)} | id: #{suspension.id}")
  IO.puts("#{String.duplicate(" ", 20)} | timeout: #{inspect(suspension.timeout)}")
  IO.puts("#{String.duplicate(" ", 20)} | metadata: #{inspect(suspension.metadata)}")
  IO.puts("")
end
```

```elixir
# Rate-limit suspension in a real workflow

defmodule Demo.RateLimitWorkflow do
  @moduledoc false
  use Jido.Composer.Workflow,
    name: "rate_limit_demo",
    description: "Workflow that suspends on rate limit",
    nodes: %{
      prepare: Demo.AccumulatorAction,
      api_call: Demo.RateLimitAction,
      finish: Demo.NoopAction
    },
    transitions: %{
      {:prepare, :ok} => :api_call,
      {:api_call, :ok} => :finish,
      {:api_call, :timeout} => :failed,
      {:finish, :ok} => :done,
      {:_, :error} => :failed
    },
    initial: :prepare

  require Demo.Helpers
  Demo.Helpers.suppress_agent_doctests()
end

# Run with tokens=0 to trigger rate limit suspension
agent = Demo.RateLimitWorkflow.new()
{agent, directives} = Demo.RateLimitWorkflow.run(agent, %{tag: "rate_test", tokens: 0})

case Demo.DirectiveRunner.run_until_done(Demo.RateLimitWorkflow, agent, directives) do
  {:suspend, suspended_agent, suspend_directive} ->
    strat = StratState.get(suspended_agent)
    suspension = strat.pending_suspension

    IO.puts("=== Rate Limit Suspension ===")
    IO.puts("Workflow suspended at state: #{strat.machine.status}")
    IO.puts("Reason:   #{suspension.reason}")
    IO.puts("Metadata: #{inspect(suspension.metadata)}")
    IO.puts("ID:       #{suspension.id}")

    # Resume with tokens available
    IO.puts("\n--- Resuming after rate limit cooldown ---")

    {resumed, resume_directives} =
      Demo.RateLimitWorkflow.cmd(suspended_agent, {
        :suspend_resume,
        %{suspension_id: suspension.id, outcome: :ok, data: %{tokens: 10}}
      })

    case Demo.DirectiveRunner.run_until_done(Demo.RateLimitWorkflow, resumed, resume_directives) do
      {:ok, final_agent} ->
        strat = StratState.get(final_agent)
        ctx = Context.to_flat_map(strat.machine.context)
        IO.puts("Workflow completed after resume!")
        IO.puts("API call result: #{inspect(ctx[:api_call])}")
        IO.puts("Final status: #{strat.status}")

      other ->
        IO.puts("Unexpected: #{inspect(other)}")
    end

  {:ok, _} ->
    IO.puts("Workflow completed without suspension (unexpected)")
end
```

```elixir
# Human-in-the-loop suspension (now a special case of generalized suspension)

defmodule Demo.HITLWorkflow do
  @moduledoc false
  use Jido.Composer.Workflow,
    name: "hitl_demo",
    description: "HITL workflow using generalized suspension",
    nodes: %{
      prepare: Demo.AccumulatorAction,
      approval: %HumanNode{
        name: "deploy_gate",
        description: "Approve or reject deployment",
        prompt: "Deployment ready. Approve?",
        allowed_responses: [:approved, :rejected],
        timeout: 60_000,
        timeout_outcome: :timeout
      },
      deploy: Demo.NoopAction
    },
    transitions: %{
      {:prepare, :ok} => :approval,
      {:approval, :approved} => :deploy,
      {:approval, :rejected} => :failed,
      {:approval, :timeout} => :failed,
      {:deploy, :ok} => :done,
      {:_, :error} => :failed
    },
    initial: :prepare

  require Demo.Helpers
  Demo.Helpers.suppress_agent_doctests()
end

agent = Demo.HITLWorkflow.new()
{agent, directives} = Demo.HITLWorkflow.run(agent, %{tag: "deploy_v2"})

case Demo.DirectiveRunner.run_until_done(Demo.HITLWorkflow, agent, directives) do
  {:suspend, suspended_agent, _suspend_directive} ->
    strat = StratState.get(suspended_agent)
    suspension = strat.pending_suspension

    IO.puts("=== HITL Suspension (Generalized) ===")
    IO.puts("Reason: #{suspension.reason}")
    IO.puts("Approval request prompt: #{suspension.approval_request.prompt}")
    IO.puts("Allowed responses: #{inspect(suspension.approval_request.allowed_responses)}")
    IO.puts("Timeout: #{suspension.timeout}ms -> outcome: #{suspension.timeout_outcome}")

    # Simulate human approval
    IO.puts("\n--- Human approves ---")
    {resumed, resume_directives} = Demo.HITLWorkflow.cmd(suspended_agent, {
      :hitl_response,
      %{
        request_id: suspension.approval_request.id,
        decision: :approved,
        respondent: "alice@acme.com",
        comment: "Looks good to deploy"
      }
    })

    case Demo.DirectiveRunner.run_until_done(Demo.HITLWorkflow, resumed, resume_directives) do
      {:ok, final} ->
        strat = StratState.get(final)
        ctx = Context.to_flat_map(strat.machine.context)
        IO.puts("Deployment approved and completed!")
        IO.puts("HITL response: #{inspect(ctx[:hitl_response])}")

      other -> IO.puts("Unexpected: #{inspect(other)}")
    end

  other -> IO.puts("Unexpected: #{inspect(other)}")
end
```

## 6. Checkpoint/Thaw -- Persisting and Restoring Suspended Agents

When an agent suspends, its entire state can be checkpointed (serialized) and stored.
Later, a fresh agent can be thawed from the checkpoint and resumed. Closures are
automatically stripped and reattached.

```elixir
# Step 1: Run a workflow until it suspends for HITL
agent = Demo.HITLWorkflow.new()
{agent, directives} = Demo.HITLWorkflow.run(agent, %{tag: "checkpoint_demo"})

{:suspend, suspended_agent, _directive} =
  Demo.DirectiveRunner.run_until_done(Demo.HITLWorkflow, agent, directives)

IO.puts("=== Checkpoint/Thaw Lifecycle ===\n")
IO.puts("Step 1: Workflow suspended for human approval")

# Step 2: Checkpoint -- strip closures
strat = StratState.get(suspended_agent)
checkpoint_data = Checkpoint.prepare_for_checkpoint(strat)

IO.puts("Step 2: Checkpoint prepared")
IO.puts("  Schema version: #{Checkpoint.schema_version()}")

# Count stripped fields
stripped = Enum.count(strat, fn {_k, v} -> is_function(v) end)
nil_after = Enum.count(checkpoint_data, fn {_, v} -> is_nil(v) end)
IO.puts("  Closures stripped: #{stripped}")

# Step 3: Serialize to binary (simulating storage)
binary = :erlang.term_to_binary(checkpoint_data, [:compressed])
IO.puts("Step 3: Serialized to #{byte_size(binary)} bytes")

# Step 4: Simulate process death + restore
IO.puts("Step 4: Process died. Creating fresh agent...")
fresh_agent = Demo.HITLWorkflow.new()

# Step 5: Thaw -- deserialize and reattach closures
restored_strat = :erlang.binary_to_term(binary)

# We need the strategy opts from the module to reattach closures
# In a real system, these come from the agent module's compile-time config
restored_strat = Checkpoint.reattach_runtime_config(restored_strat, [])
restored_agent = StratState.put(fresh_agent, restored_strat)

IO.puts("Step 5: Agent thawed from checkpoint")
IO.puts("  Status: #{restored_strat.status}")
IO.puts("  Pending suspension: #{restored_strat.pending_suspension.reason}")
IO.puts("  Suspension ID: #{restored_strat.pending_suspension.id}")

# Step 6: Resume using the Resume module
suspension_id = restored_strat.pending_suspension.id

{:ok, resumed_agent, resume_directives} = Resume.resume(
  restored_agent,
  suspension_id,
  %{
    request_id: restored_strat.pending_suspension.approval_request.id,
    decision: :approved,
    respondent: "bob@acme.com"
  },
  deliver_fn: fn agent, signal ->
    Demo.HITLWorkflow.cmd(agent, signal)
  end
)

IO.puts("Step 6: Resumed via Resume.resume/4")

case Demo.DirectiveRunner.run_until_done(Demo.HITLWorkflow, resumed_agent, resume_directives) do
  {:ok, final} ->
    strat = StratState.get(final)
    IO.puts("Step 7: Workflow completed! Status: #{strat.status}")
    IO.puts("\nFull lifecycle: Run -> Suspend -> Checkpoint -> Serialize -> Death -> Thaw -> Resume -> Complete")
  other ->
    IO.puts("Unexpected: #{inspect(other)}")
end
```

```elixir
# Schema evolution: migrating old checkpoints

old_v1_checkpoint = %{
  status: :waiting,
  machine: %{status: :approval},
  pending_suspension: nil
  # Note: no :children field -- this is a v1 checkpoint
}

migrated = Checkpoint.migrate(old_v1_checkpoint, 1)

IO.puts("=== Schema Evolution ===")
IO.puts("v1 checkpoint had #{map_size(old_v1_checkpoint)} fields")
IO.puts("After migration: #{map_size(migrated)} fields")
IO.puts("New :children field: #{inspect(migrated[:children])}")
```

## 7. Grand Finale -- The Full Stack

This is the complex scenario: a **document review pipeline** where workflows and agents
compose at multiple levels, a sub-agent suspends for human approval deep in the tree,
the entire pipeline checkpoints, and we resume it later.

```mermaid
graph TD
    subgraph Outer Workflow
        A[Prepare] --> B[FanOut: Parallel Analysis]
        B --> C[Review Gate - HumanNode]
        C -->|approved| D[Publish]
        C -->|rejected| E[Failed]
        D --> F[Done]
    end

    subgraph "FanOut Branches (parallel)"
        B --> B1[Branch: Extract - ActionNode]
        B --> B2[Branch: Analyze - Inner Workflow Agent]
        B --> B3[Branch: Validate - ActionNode]
    end

    subgraph "Inner Analyze Agent (Workflow)"
        B2 --> G[Transform]
        G --> H[Load]
    end
```

```elixir
# Custom actions for the grand finale

defmodule Demo.PrepareDocsAction do
  use Jido.Action,
    name: "prepare_docs",
    description: "Gathers documents for review",
    schema: [
      doc_ids: [type: {:list, :string}, required: false],
      source: [type: :string, required: false]
    ]

  def run(params, _ctx) do
    doc_ids = Map.get(params, :doc_ids, ["DOC-001", "DOC-002", "DOC-003"])
    source = Map.get(params, :source, "default")
    {:ok, %{
      documents: Enum.map(doc_ids, &%{id: &1, source: source, status: :pending}),
      count: length(doc_ids),
      gathered_at: DateTime.utc_now() |> DateTime.to_iso8601()
    }}
  end
end

defmodule Demo.ValidateDocsAction do
  use Jido.Action,
    name: "validate_docs",
    description: "Validates document format and compliance",
    schema: []

  def run(params, _ctx) do
    docs = get_in(params, [:parallel, :extract, :documents]) ||
           get_in(params, [:extract, :documents]) || []

    results = Enum.map(docs, fn doc ->
      %{id: doc[:id], valid: true, compliance_score: Enum.random(85..100)}
    end)

    {:ok, %{validations: results, all_valid: Enum.all?(results, & &1.valid)}}
  end
end

defmodule Demo.PublishAction do
  use Jido.Action,
    name: "publish",
    description: "Publishes reviewed documents",
    schema: []

  def run(params, _ctx) do
    doc_count = get_in(params, [:parallel, :extract, :count]) || 0
    {:ok, %{
      published: doc_count,
      published_at: DateTime.utc_now() |> DateTime.to_iso8601(),
      reviewer: get_in(params, [:hitl_response, :respondent]) || "unknown"
    }}
  end
end

IO.puts("Grand Finale actions defined.")
```

```elixir
# Inner analysis agent -- a workflow that runs inside a FanOut branch

defmodule Demo.AnalysisAgent do
  @moduledoc false
  use Jido.Composer.Workflow,
    name: "analysis_agent",
    description: "Runs transform+load as a nested agent inside FanOut",
    nodes: %{
      transform: Demo.TransformAction,
      load: Demo.LoadAction
    },
    transitions: %{
      {:transform, :ok} => :load,
      {:load, :ok} => :done,
      {:_, :error} => :failed
    },
    initial: :transform

  require Demo.Helpers
  Demo.Helpers.suppress_agent_doctests()
end

# The grand workflow: prepare -> parallel analysis -> human review gate -> publish
#
# Note: FanOutNode and HumanNode with function prompts contain closures that
# can't be Macro.escape'd into the `use Workflow` DSL in Livebook's eval context.
# We define a module that constructs the workflow at runtime via `new/0` override.
defmodule Demo.DocumentReviewPipeline do
  @moduledoc false
  use Jido.Composer.Workflow,
    name: "document_review",
    description: "Multi-level pipeline with FanOut, nested agents, HITL, and checkpoint",
    nodes: %{
      prepare: Demo.PrepareDocsAction,
      parallel: Demo.PrepareDocsAction,
      review: Demo.NoopAction,
      publish: Demo.PublishAction
    },
    transitions: %{
      {:prepare, :ok} => :parallel,
      {:parallel, :ok} => :review,
      {:review, :approved} => :publish,
      {:review, :rejected} => :failed,
      {:review, :timeout} => :failed,
      {:publish, :ok} => :done,
      {:_, :error} => :failed
    },
    initial: :prepare,
    ambient: [:org_id, :project_id]

  require Demo.Helpers
  Demo.Helpers.suppress_agent_doctests()
end

# Helper to create a patched agent with runtime nodes (FanOut + HumanNode)
# These can't live inside the `use Workflow` macro due to Macro.escape limitations.
defmodule Demo.DocumentReviewPipelineHelper do
  def new_patched do
    {:ok, extract_node} = ActionNode.new(Demo.PrepareDocsAction)
    {:ok, analysis_node} = AgentNode.new(Demo.AnalysisAgent)
    {:ok, validate_node} = ActionNode.new(Demo.ValidateDocsAction)

    {:ok, parallel_analysis} = FanOutNode.new(
      name: "parallel_analysis",
      branches: [
        extract: extract_node,
        analyze: analysis_node,
        validate: validate_node
      ],
      max_concurrency: 2,
      on_error: :collect_partial
    )

    review_node = %HumanNode{
      name: "review_gate",
      description: "Human reviewer approves or rejects the analysis",
      prompt: "Documents analyzed. Approve for publication?",
      allowed_responses: [:approved, :rejected],
      context_keys: [:prepare, :parallel],
      timeout: 120_000,
      timeout_outcome: :timeout
    }

    agent = Demo.DocumentReviewPipeline.new()
    StratState.update(agent, fn strat ->
      nodes = %{strat.machine.nodes | parallel: parallel_analysis, review: review_node}
      %{strat | machine: %{strat.machine | nodes: nodes}}
    end)
  end
end

IO.puts("Grand Finale pipeline defined.")
IO.puts("Nodes: prepare -> parallel(extract+analyze+validate) -> review(HITL) -> publish")
```

```elixir
# --- Phase 1: Run until human review suspension ---

IO.puts("=" |> String.duplicate(70))
IO.puts("  GRAND FINALE: Document Review Pipeline")
IO.puts("=" |> String.duplicate(70))

agent = Demo.DocumentReviewPipelineHelper.new_patched()

{agent, directives} = Demo.DocumentReviewPipeline.run(agent, %{
  source: "legal_repo",
  doc_ids: ["CONTRACT-A", "CONTRACT-B", "AMENDMENT-1"],
  org_id: "acme-legal",
